<odoo>

     View tree definition: بنعمل شاشة List View للـ building
    <record id="building_view_tree" model="ir.ui.view">
        <!-- اسم الفيو للتمييز -->
        <field name="name">building tree</field>

        <!-- الموديل اللي الفيو تابع ليه -->
        <field name="model">building</field>

        <!-- شكل الفيو من جوه -->
        <field name="arch" type="xml">
            <tree class="header_custom" >
                 <field name="name"/>
                <field name="number"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="building_view_form" model="ir.ui.view">
        <!-- اسم الفيو للتمييز -->
        <field name="name">building form</field>

        <!-- الموديل اللي الفيو تابع ليه -->
        <field name="model">building</field>

        <!-- شكل الفيو من جوه -->
        <field name="arch" type="xml">
            <form >
                <sheet>
                    <group>
                        <group string="General info.">
                             <field name="name"/>
                            <field name="number"/>
                        </group>
                        <group string="Additional info.">
                           <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                          <field name="description"/>
                        </group>

                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>
    <record id="building_view_search"  model="ir.ui.view">
        <field name="name">building search</field>
        <field name="model">building</field>
        <field name="arch" type="xml">
            <search>
                <field name="number"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- Action: بنعمل action يفتح شاشة الموديل -->
    <record id="building_action" model="ir.actions.act_window">
        <field name="name">building action</field>
        <field name="res_model">building</field>
<!--        <field name="view_mode">tree,form</field>-->
    </record>

    <!-- Menu item: بنعمل Menu تظهر في Odoo وتفتح الـ action -->
    <menuitem
        id="building_menu_item"
        name="Buildings"
        parent="properties_menu"
        action="building_action"
    />

</odoo>
